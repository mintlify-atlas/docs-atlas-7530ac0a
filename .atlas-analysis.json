  "projectType": "cli-tool",
  "projectName": "xcodes",
  "projectDescription": "A macOS command-line tool for installing, managing, and switching between multiple versions of Xcode and simulator runtimes.",
  "theme": "palm",
  "primaryColor": "#585858",
  "lightColor": "#3d3d3d",
  "darkColor": "#b5b5b5",
